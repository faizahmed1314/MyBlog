<MudPaper Class="@($"ds-hero {Class}")" Elevation="0">
    @if (!string.IsNullOrWhiteSpace(Eyebrow))
    {
        <div class="ds-hero-eyebrow">@Eyebrow</div>
    }

    <h1 class="ds-hero-title">@Title</h1>
    <p class="ds-hero-description mb-0">@Description</p>

    @if (Actions is not null)
    {
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Class="mt-4">
            @Actions
        </MudStack>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }
}