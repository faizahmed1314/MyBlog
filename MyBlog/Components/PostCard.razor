@using MyBlog.Models

<MudCard Class="h-100 post-card" Outlined="true">
    @if (!string.IsNullOrWhiteSpace(Post.ThumbnailUrl))
    {
        <MudCardMedia Image="@Post.ThumbnailUrl" Height="180" Class="post-thumbnail" />
    }

    <MudCardContent>
        <MudText Typo="Typo.caption" Class="mb-2 text-muted">
            @Post.PublishedOn.ToString("MMM dd, yyyy") · @Post.ReadingTimeMinutes min read
        </MudText>

        <MudText Typo="Typo.h6" Class="mb-2">@Post.Title</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@Post.Summary</MudText>

        @if (Post.Tags.Length > 0)
        {
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
                @foreach (var tag in Post.Tags)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@tag</MudChip>
                }
            </MudStack>
        }

        <MudButton Href="@($"/post/{Post.Slug}")" Variant="Variant.Filled" Color="Color.Primary">Read more</MudButton>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public PostSummary Post { get; set; } = default!;
}