@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="app-shell">
    <NavMenu />

    <MudMainContent Class="app-content">
        <MudContainer MaxWidth="MaxWidth.Large">
            @Body
        </MudContainer>
    </MudMainContent>

    <Footer />
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#512BD4",
            Secondary = "#6F42C1",
            Info = "#0EA5E9",
            Background = "#F6F8FC",
            Surface = "#FFFFFF",
            AppbarBackground = "#1A1F36",
            AppbarText = "#FFFFFF",
            TextPrimary = "#111827",
            TextSecondary = "#4B5563"
        }
    };
}