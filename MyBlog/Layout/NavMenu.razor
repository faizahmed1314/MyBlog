<MudAppBar Elevation="0" Dense="true" Class="blog-appbar px-3 px-md-6">
    <MudContainer MaxWidth="MaxWidth.Large" Class="top-nav-shell pa-0">
        <MudText Typo="Typo.h6" Class="blog-brand">MyBlog</MudText>
        <MudSpacer />

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudNavMenu Class="d-flex flex-row pa-0 nav-inline">
                <MudNavLink Href="/" Match="NavLinkMatch.All" Class="top-nav-link">Home</MudNavLink>
                <MudNavLink Href="/about" Class="top-nav-link">About</MudNavLink>
                <MudNavLink Href="/contact" Class="top-nav-link">Contact</MudNavLink>
            </MudNavMenu>
        </MudHidden>

        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudMenu Label="Menu" Variant="Variant.Text" Color="Color.Inherit" Dense="true">
                <MudMenuItem Href="/">Home</MudMenuItem>
                <MudMenuItem Href="/about">About</MudMenuItem>
                <MudMenuItem Href="/contact">Contact</MudMenuItem>
            </MudMenu>
        </MudHidden>
    </MudContainer>
</MudAppBar>